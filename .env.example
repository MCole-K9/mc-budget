# PocketBase Configuration
# Default for local dev: http://127.0.0.1:8090
# In Docker this is set automatically via build args — no need to change it
PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase superuser credentials
# Used by the SvelteKit app for admin DB access, and by the Docker entrypoint to create the superuser
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# Anthropic API key — fallback for receipt scanning (users can also set their own in Settings)
ANTHROPIC_API_KEY=

# SvelteKit body size limit — increase for receipt file uploads (default: 512K)
BODY_SIZE_LIMIT=5M
